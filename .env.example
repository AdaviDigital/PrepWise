# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5500
# Comma-separated list of additional allowed origins (production frontend domains)
CORS_ORIGINS=https://www.prepwise.ng,https://prepwise.ng

# ── Database (Neon Postgres) ─────────────────────────────────────────────
# Get this from your Neon project dashboard. Keep "sslmode=require".
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST.neon.tech/prepwise?sslmode=require"
# Neon's pooled connection string (use for serverless/edge if different from DATABASE_URL)
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST.neon.tech/prepwise?sslmode=require"

# ── Redis (Upstash) — sessions, rate limiting, AI response cache ────────
REDIS_URL="rediss://default:PASSWORD@YOUR-UPSTASH-HOST.upstash.io:6379"

# ── Auth / JWT ────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=replace_with_another_long_random_string

# ── OAuth ─────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_oauth_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_oauth_client_secret
MICROSOFT_TENANT_ID=common

# ── OpenAI (AI Tutor / RAG) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── File storage (Cloudinary) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ── AWS S3 (alternative/secondary storage) ───────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-1
AWS_S3_BUCKET=prepwise-uploads

# ── Payments ──────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notifications ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
EMAIL_FROM="PrepWise <no-reply@prepwise.ng>"

TERMII_API_KEY=your_termii_or_sms_provider_key
TERMII_SENDER_ID=PrepWise

WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_business_phone_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token

# ── Security ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20
